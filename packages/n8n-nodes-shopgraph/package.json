{
  "name": "n8n-nodes-shopgraph",
  "version": "1.0.0",
  "description": "n8n community node for product data extraction with per-field confidence scoring and extraction provenance. Returns UCP-compliant JSON.",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "shopgraph",
    "product-data",
    "extraction",
    "commerce",
    "confidence-scoring",
    "ucp",
    "agent"
  ],
  "license": "MIT",
  "homepage": "https://shopgraph.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/shopgraph/n8n-nodes-shopgraph"
  },
  "main": "dist/index.js",
  "files": [
    "dist/**/*",
    "nodes/**/*.svg"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/ShopGraphApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/ShopGraph/ShopGraph.node.js"
    ]
  },
  "scripts": {
    "build": "tsc && npm run copy-assets",
    "copy-assets": "cp nodes/ShopGraph/ShopGraph.node.json dist/nodes/ShopGraph/ && cp nodes/ShopGraph/shopgraph.svg dist/nodes/ShopGraph/",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "devDependencies": {
    "n8n-workflow": "^1.0.0",
    "typescript": "^5.0.0"
  }
}
