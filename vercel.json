{
  "version": 2,
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "outputDirectory": ".",
  "framework": null,
  "functions": {
    "api/index.ts": {
      "maxDuration": 60,
      "includeFiles": "src/**,data/**"
    }
  },
  "rewrites": [
    { "source": "/health", "destination": "/api" },
    { "source": "/mcp", "destination": "/api" },
    { "source": "/api/:path*", "destination": "/api" }
  ],
  "cleanUrls": true,
  "crons": [
    {
      "path": "/api/run-tests",
      "schedule": "*/30 * * * *"
    }
  ]
}