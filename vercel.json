{
  "version": 2,
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "outputDirectory": ".",
  "framework": null,
  "functions": {
    "api/index.ts": {
      "maxDuration": 60,
      "includeFiles": "src/**,data/**"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api"
    }
  ],
  "crons": [
    {
      "path": "/api/run-tests",
      "schedule": "*/30 * * * *"
    }
  ]
}