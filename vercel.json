{
  "version": 2,
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "framework": null,
  "functions": {
    "api/index.ts": {
      "maxDuration": 60,
      "memory": 1024,
      "includeFiles": "src/**,data/**"
    }
  },
  "rewrites": [
    {
      "source": "/.well-known/:path*",
      "destination": "/api"
    },
    {
      "source": "/health",
      "destination": "/api"
    },
    {
      "source": "/mcp",
      "destination": "/api"
    },
    {
      "source": "/api/:path*",
      "destination": "/api"
    }
  ],
  "cleanUrls": true,
  "crons": [
    {
      "path": "/api/run-tests",
      "schedule": "0 * * * *"
    }
  ]
}
